# Скопіюй цей файл у .env і заповни своїми значеннями (для локального запуску).
# .env НЕ комітиться в git (він у .gitignore).

TELEGRAM_BOT_TOKEN=встав_сюди_токен_від_BotFather
TELEGRAM_CHAT_ID=встав_сюди_свій_chat_id

# Необовʼязково (нижче — значення за замовчуванням):
# WATCH_URLS=https://wroclaw.pasport.org.ua/solutions/e-queue
# USE_BROWSER=0            # 0 = простий HTTP (сайт рендериться на сервері — цього досить і це швидше); 1 = браузер (Playwright)
# RENDER_WAIT_MS=4000      # лише для USE_BROWSER=1
# COOLDOWN_MIN=30          # пауза між повторними нагадуваннями «є місця»
# LOOP_SECONDS=0           # 0 = один прогін; напр. 300 = кожні 5 хв (локально)

# Сповіщення про «здоровʼя» автомата:
# HEARTBEAT_HOURS=24       # раз на скільки годин слати «я живий»; 0 = вимкнути
# ERROR_ALERT_AFTER=3      # скільки збоїв поспіль до сповіщення «не можу перевірити»

# Тонке налаштування розпізнавання (зазвичай чіпати не треба):
# UNAVAILABLE_PHRASES=всі місця зайняті|немає вільних|запис відсутній
# AVAILABLE_MARKERS=queueform|qlogickform
# PAGE_MARKERS=черг|запис|e-queue|послуг
